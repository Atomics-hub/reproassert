{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Atomics-hub/reproassert/blob/main/schemas/benchmark-v02-campaign-finalization.schema.json",
  "title": "ReproAssert v0.2 private campaign finalization",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "benchmark_version",
    "algorithm",
    "visibility",
    "status",
    "campaign_id",
    "finalized_at",
    "campaign_freeze_sha256",
    "preregistration_sha256",
    "cohort_sha256",
    "generation_barrier_sha256",
    "ledger_sha256",
    "ledger_head_event_sha256",
    "causal_control_set_sha256",
    "semantic_review_set_sha256",
    "candidate_freeze_barrier_verified",
    "attempt_count",
    "cases",
    "tool",
    "public_aggregate_sha256"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "benchmark_version": { "const": "0.2.0-draft" },
    "algorithm": { "const": "reproassert-v02-campaign-finalization-v1" },
    "visibility": { "const": "private_controller_only" },
    "status": { "const": "complete" },
    "campaign_id": { "$ref": "#/$defs/identifier" },
    "finalized_at": { "$ref": "#/$defs/timestamp" },
    "campaign_freeze_sha256": { "$ref": "#/$defs/sha256" },
    "preregistration_sha256": { "$ref": "#/$defs/sha256" },
    "cohort_sha256": { "$ref": "#/$defs/sha256" },
    "generation_barrier_sha256": { "$ref": "#/$defs/sha256" },
    "ledger_sha256": { "$ref": "#/$defs/sha256" },
    "ledger_head_event_sha256": { "$ref": "#/$defs/sha256" },
    "causal_control_set_sha256": { "$ref": "#/$defs/sha256" },
    "semantic_review_set_sha256": { "$ref": "#/$defs/sha256" },
    "candidate_freeze_barrier_verified": { "const": true },
    "attempt_count": { "const": 20 },
    "cases": {
      "type": "array",
      "minItems": 20,
      "maxItems": 20,
      "items": { "$ref": "#/$defs/case" }
    },
    "tool": { "$ref": "#/$defs/tool" },
    "public_aggregate_sha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "git_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{2,127}$"
    },
    "case_id": { "type": "string", "pattern": "^rk-v0\\.2-[0-9]{3}$" },
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$"
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "attempt_id",
        "private_result_sha256",
        "embargoed_result_sha256",
        "causal_control_receipt_sha256",
        "semantic_review_case_sha256",
        "terminal_event_sha256"
      ],
      "properties": {
        "case_id": { "$ref": "#/$defs/case_id" },
        "attempt_id": { "$ref": "#/$defs/identifier" },
        "private_result_sha256": { "$ref": "#/$defs/sha256" },
        "embargoed_result_sha256": { "$ref": "#/$defs/sha256" },
        "causal_control_receipt_sha256": { "$ref": "#/$defs/sha256" },
        "semantic_review_case_sha256": { "$ref": "#/$defs/sha256" },
        "terminal_event_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "git_sha"],
      "properties": {
        "name": { "$ref": "#/$defs/identifier" },
        "version": { "type": "string", "minLength": 1, "maxLength": 64 },
        "git_sha": { "$ref": "#/$defs/git_sha" }
      }
    }
  }
}
