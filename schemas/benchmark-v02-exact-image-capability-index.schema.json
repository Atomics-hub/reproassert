{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Atomics-hub/reproassert/blob/main/schemas/benchmark-v02-exact-image-capability-index.schema.json",
  "title": "ReproAssert v0.2 exact-image capability commitment index",
  "type": "object",
  "additionalProperties": false,
  "required": ["algorithm", "benchmark_version", "case_count", "cases", "claims", "index_sha256", "prepared_at", "schema_version", "status", "tool_git_sha"],
  "properties": {
    "algorithm": {"const": "reproassert-v02-exact-image-capability-index-v1"},
    "benchmark_version": {"const": "0.2"},
    "case_count": {"const": 20},
    "cases": {
      "type": "array", "minItems": 20, "maxItems": 20,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["case_id", "evaluator_public_commitment_sha256", "evidence", "status"],
        "properties": {
          "case_id": {"$ref": "#/$defs/case_id"},
          "evaluator_public_commitment_sha256": {"$ref": "#/$defs/sha256"},
          "evidence": {
            "type": "object", "additionalProperties": false,
            "required": ["algorithm", "case_id", "gold_smoke", "hidden_inputs", "runtime", "runtime_manifest_sha256"],
            "properties": {
              "algorithm": {"const": "reproassert-v02-exact-image-evaluator-capability-v1"},
              "case_id": {"$ref": "#/$defs/case_id"},
              "gold_smoke": {
                "type": "object", "additionalProperties": false,
                "required": ["case_classification", "case_reason", "receipt_commitment_sha256", "receipt_sha256"],
                "properties": {
                  "case_classification": {"enum": ["semantic_valid", "infrastructure_failure"]},
                  "case_reason": {"enum": ["fails_on_base_passes_on_fixed", "network_dependency"]},
                  "receipt_commitment_sha256": {"$ref": "#/$defs/sha256"},
                  "receipt_sha256": {"$ref": "#/$defs/sha256"}
                }
              },
              "hidden_inputs": {
                "type": "object", "additionalProperties": false,
                "required": ["developer_tests_bytes", "developer_tests_sha256", "hidden_extraction_receipt_sha256", "production_patch_bytes", "production_patch_sha256"],
                "properties": {
                  "developer_tests_bytes": {"type": "integer", "minimum": 1},
                  "developer_tests_sha256": {"$ref": "#/$defs/sha256"},
                  "hidden_extraction_receipt_sha256": {"$ref": "#/$defs/sha256"},
                  "production_patch_bytes": {"type": "integer", "minimum": 1},
                  "production_patch_sha256": {"$ref": "#/$defs/sha256"}
                }
              },
              "runtime": {
                "type": "object", "additionalProperties": false,
                "required": ["base_sha", "base_tree_oid", "case_id", "image_digest", "image_id", "image_tag", "instance_id", "spec_sha256", "test_command_profile"],
                "properties": {
                  "base_sha": {"$ref": "#/$defs/git_sha"},
                  "base_tree_oid": {"$ref": "#/$defs/git_sha"},
                  "case_id": {"$ref": "#/$defs/case_id"},
                  "image_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
                  "image_id": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
                  "image_tag": {"type": "string", "minLength": 8, "maxLength": 300},
                  "instance_id": {"type": "string", "minLength": 3, "maxLength": 200},
                  "spec_sha256": {"$ref": "#/$defs/sha256"},
                  "test_command_profile": {"enum": ["pytest-v1", "sympy-bin-test-v1"]}
                }
              },
              "runtime_manifest_sha256": {"$ref": "#/$defs/sha256"}
            }
          },
          "status": {"enum": ["runtime_attested_evaluator_preflight_ready", "runtime_attested_gold_smoke_infrastructure_failure"]}
        }
      }
    },
    "claims": {
      "const": {
        "evaluator_preflight_ready_count": 19,
        "infrastructure_failure_count": 1,
        "nominal_authority_serialized": false,
        "provider_calls": 0,
        "runtime_attested_count": 20
      }
    },
    "index_sha256": {"$ref": "#/$defs/sha256"},
    "prepared_at": {"$ref": "#/$defs/timestamp"},
    "schema_version": {"const": "1.0.0"},
    "status": {"const": "runtime_attested_20_evaluator_preflight_19"},
    "tool_git_sha": {"$ref": "#/$defs/git_sha"}
  },
  "$defs": {
    "case_id": {"type": "string", "pattern": "^rk-v0\\.2-[0-9]{3}$"},
    "git_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "timestamp": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$"}
  }
}

