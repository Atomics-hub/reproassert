{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Atomics-hub/reproassert/blob/main/schemas/benchmark-v02-semantic-review-set.schema.json",
  "title": "ReproAssert v0.2 blinded multi-reviewer semantic evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "benchmark_version",
    "algorithm",
    "status",
    "campaign_id",
    "campaign_freeze_sha256",
    "preregistration_sha256",
    "cohort_sha256",
    "sealed_at",
    "review_contract",
    "cases",
    "tool",
    "review_set_sha256"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "benchmark_version": { "const": "0.2.0-draft" },
    "algorithm": { "const": "reproassert-v02-blinded-semantic-review-v1" },
    "status": { "const": "sealed_complete" },
    "campaign_id": { "$ref": "#/$defs/identifier" },
    "campaign_freeze_sha256": { "$ref": "#/$defs/sha256" },
    "preregistration_sha256": { "$ref": "#/$defs/sha256" },
    "cohort_sha256": { "$ref": "#/$defs/sha256" },
    "sealed_at": { "$ref": "#/$defs/timestamp" },
    "review_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reviewer_role",
        "role_evidence",
        "two_reviewers_required_per_candidate",
        "third_reviewer_only_breaks_disagreement",
        "mapping_and_semantic_reviewer_ids_disjoint",
        "issue_snapshot_accessed",
        "candidate_accessed",
        "normalized_base_failure_accessed",
        "fixed_pass_evidence_accessed",
        "declared_causal_controls_accessed",
        "developer_tests_accessed",
        "human_patch_accessed",
        "mechanical_verdict_label_accessed",
        "gold_hidden_until_verdict"
      ],
      "properties": {
        "reviewer_role": { "const": "declared_blinded_semantic_reviewer" },
        "role_evidence": {
          "const": "opaque_package_role_seal_commitment_not_reopened"
        },
        "two_reviewers_required_per_candidate": { "const": true },
        "third_reviewer_only_breaks_disagreement": { "const": true },
        "mapping_and_semantic_reviewer_ids_disjoint": { "const": true },
        "issue_snapshot_accessed": { "const": true },
        "candidate_accessed": { "const": true },
        "normalized_base_failure_accessed": { "const": true },
        "fixed_pass_evidence_accessed": { "const": true },
        "declared_causal_controls_accessed": { "const": true },
        "developer_tests_accessed": { "const": false },
        "human_patch_accessed": { "const": false },
        "mechanical_verdict_label_accessed": { "const": false },
        "gold_hidden_until_verdict": { "const": true }
      }
    },
    "cases": {
      "type": "array",
      "minItems": 20,
      "maxItems": 20,
      "items": { "$ref": "#/$defs/review_case" }
    },
    "tool": { "$ref": "#/$defs/tool" },
    "review_set_sha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "git_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{2,127}$"
    },
    "case_id": { "type": "string", "pattern": "^rk-v0\\.2-[0-9]{3}$" },
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$"
    },
    "review_case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "candidate_sha256",
        "causal_control_receipt_sha256",
        "status",
        "reviewer_role_seal_sha256",
        "mapping_reviewer_ids",
        "authorized_semantic_reviewer_ids",
        "reviews",
        "reviewer_count",
        "consensus_verdict",
        "tiebreak_used",
        "review_case_sha256"
      ],
      "properties": {
        "case_id": { "$ref": "#/$defs/case_id" },
        "candidate_sha256": {
          "oneOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }]
        },
        "causal_control_receipt_sha256": { "$ref": "#/$defs/sha256" },
        "status": { "enum": ["sealed_consensus", "not_applicable_no_candidate"] },
        "reviewer_role_seal_sha256": {
          "oneOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }]
        },
        "mapping_reviewer_ids": {
          "type": "array",
          "maxItems": 4,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/identifier" }
        },
        "authorized_semantic_reviewer_ids": {
          "type": "array",
          "maxItems": 3,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/identifier" }
        },
        "reviews": {
          "type": "array",
          "maxItems": 3,
          "items": { "$ref": "#/$defs/review" }
        },
        "reviewer_count": { "enum": [0, 2, 3] },
        "consensus_verdict": {
          "enum": [
            "semantically_valid",
            "semantically_invalid",
            "not_applicable_no_candidate"
          ]
        },
        "tiebreak_used": { "type": "boolean" },
        "review_case_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "review_round",
        "candidate_sha256",
        "causal_control_receipt_sha256",
        "reviewer_id",
        "reviewer_role_seal_sha256",
        "fixed_pass_evidence_sha256",
        "checklist_sha256",
        "reviewed_at",
        "trigger_faithful",
        "oracle_supported",
        "failure_causal",
        "implementation_independent",
        "minimal_readable",
        "confidence",
        "rationale",
        "verdict",
        "status",
        "reviewer_role",
        "issue_snapshot_accessed",
        "candidate_accessed",
        "normalized_base_failure_accessed",
        "fixed_pass_evidence_accessed",
        "declared_causal_controls_accessed",
        "developer_tests_accessed",
        "human_patch_accessed",
        "mechanical_verdict_label_accessed",
        "gold_hidden_until_verdict",
        "review_sha256"
      ],
      "properties": {
        "case_id": { "$ref": "#/$defs/case_id" },
        "review_round": { "type": "integer", "minimum": 1, "maximum": 3 },
        "candidate_sha256": { "$ref": "#/$defs/sha256" },
        "causal_control_receipt_sha256": { "$ref": "#/$defs/sha256" },
        "reviewer_id": { "$ref": "#/$defs/identifier" },
        "reviewer_role_seal_sha256": { "$ref": "#/$defs/sha256" },
        "fixed_pass_evidence_sha256": { "$ref": "#/$defs/sha256" },
        "checklist_sha256": { "$ref": "#/$defs/sha256" },
        "reviewed_at": { "$ref": "#/$defs/timestamp" },
        "trigger_faithful": { "type": "boolean" },
        "oracle_supported": { "type": "boolean" },
        "failure_causal": { "type": "boolean" },
        "implementation_independent": { "type": "boolean" },
        "minimal_readable": { "type": "boolean" },
        "confidence": { "enum": ["low", "medium", "high"] },
        "rationale": { "type": "string", "minLength": 20, "maxLength": 2000 },
        "verdict": { "enum": ["semantically_valid", "semantically_invalid"] },
        "status": { "const": "sealed" },
        "reviewer_role": { "const": "declared_blinded_semantic_reviewer" },
        "issue_snapshot_accessed": { "const": true },
        "candidate_accessed": { "const": true },
        "normalized_base_failure_accessed": { "const": true },
        "fixed_pass_evidence_accessed": { "const": true },
        "declared_causal_controls_accessed": { "const": true },
        "developer_tests_accessed": { "const": false },
        "human_patch_accessed": { "const": false },
        "mechanical_verdict_label_accessed": { "const": false },
        "gold_hidden_until_verdict": { "const": true },
        "review_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "git_sha"],
      "properties": {
        "name": { "$ref": "#/$defs/identifier" },
        "version": { "type": "string", "minLength": 1, "maxLength": 64 },
        "git_sha": { "$ref": "#/$defs/git_sha" }
      }
    }
  }
}
