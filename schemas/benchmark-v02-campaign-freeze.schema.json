{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Atomics-hub/reproassert/blob/main/schemas/benchmark-v02-campaign-freeze.schema.json",
  "title": "ReproAssert v0.2 preparation-only campaign freeze",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "benchmark_version",
    "algorithm",
    "status",
    "campaign_id",
    "prepared_at",
    "preregistration_sha256",
    "cohort_sha256",
    "case_count",
    "case_ids",
    "execution_contract",
    "tool",
    "campaign_freeze_sha256"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "benchmark_version": { "const": "0.2.0-draft" },
    "algorithm": { "const": "reproassert-v02-campaign-freeze-v1" },
    "status": { "const": "prepared_no_provider_authorized" },
    "campaign_id": { "$ref": "#/$defs/identifier" },
    "prepared_at": { "$ref": "#/$defs/timestamp" },
    "preregistration_sha256": { "$ref": "#/$defs/sha256" },
    "cohort_sha256": { "$ref": "#/$defs/sha256" },
    "case_count": { "const": 20 },
    "case_ids": {
      "type": "array",
      "minItems": 20,
      "maxItems": 20,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/case_id" }
    },
    "execution_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "expected_attempt_count",
        "candidate_budget_per_case",
        "all_20_generation_dispositions_before_first_evaluator_phase",
        "generation_barrier_algorithm",
        "durable_barrier_seal_event_required",
        "per_case_publication",
        "paid_execution_exposed_by_cli",
        "provider_authorization"
      ],
      "properties": {
        "expected_attempt_count": { "const": 20 },
        "candidate_budget_per_case": { "const": 1 },
        "all_20_generation_dispositions_before_first_evaluator_phase": { "const": true },
        "generation_barrier_algorithm": {
          "const": "reproassert-v02-campaign-generation-barrier-v1"
        },
        "durable_barrier_seal_event_required": { "const": true },
        "per_case_publication": { "const": "embargoed_until_campaign_finalization" },
        "paid_execution_exposed_by_cli": { "const": false },
        "provider_authorization": { "const": "not_included" }
      }
    },
    "tool": { "$ref": "#/$defs/tool" },
    "campaign_freeze_sha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "git_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{2,127}$"
    },
    "case_id": { "type": "string", "pattern": "^rk-v0\\.2-[0-9]{3}$" },
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$"
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "git_sha"],
      "properties": {
        "name": { "$ref": "#/$defs/identifier" },
        "version": { "type": "string", "minLength": 1, "maxLength": 64 },
        "git_sha": { "$ref": "#/$defs/git_sha" }
      }
    }
  }
}
