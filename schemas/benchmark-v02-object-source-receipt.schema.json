{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Atomics-hub/reproassert/blob/main/schemas/benchmark-v02-object-source-receipt.schema.json",
  "title": "ReproAssert benchmark v0.2 exact-object source receipt",
  "description": "Preparation-only evidence binding one frozen case to a Git object tree, bounded codeload transport, exact repair blobs, and a removed metadata-free workspace. It is not a campaign result.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "benchmark_version",
    "case",
    "manifest",
    "source",
    "acquisition",
    "tool",
    "campaign_readiness_changed"
  ],
  "properties": {
    "schema_version": { "const": "2.0.0" },
    "kind": { "const": "benchmark_object_source_receipt" },
    "benchmark_version": { "const": "0.2.0" },
    "campaign_readiness_changed": { "const": false },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "repository", "issue_url", "issue_number", "base_sha"],
      "properties": {
        "id": { "type": "string", "pattern": "^rk-v0\\.2-(00[1-9]|01[0-9]|020)$" },
        "repository": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
        "issue_url": { "type": "string", "pattern": "^https://github\\.com/[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+/issues/[1-9][0-9]*$" },
        "issue_number": { "$ref": "#/$defs/positive_integer" },
        "base_sha": { "$ref": "#/$defs/git_oid" }
      }
    },
    "manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["raw_sha256", "case_entry_sha256"],
      "properties": {
        "raw_sha256": { "$ref": "#/$defs/sha256" },
        "case_entry_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository_url",
        "base_sha",
        "github_root_tree_oid",
        "object_snapshot",
        "transport",
        "verified_workspace"
      ],
      "properties": {
        "repository_url": { "type": "string", "pattern": "^https://github\\.com/[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
        "base_sha": { "$ref": "#/$defs/git_oid" },
        "github_root_tree_oid": { "$ref": "#/$defs/git_oid" },
        "object_snapshot": { "$ref": "#/$defs/object_snapshot" },
        "transport": { "$ref": "#/$defs/transport" },
        "verified_workspace": { "$ref": "#/$defs/verified_workspace" }
      }
    },
    "acquisition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy", "policy_sha256", "runtime"],
      "properties": {
        "policy": { "$ref": "#/$defs/policy" },
        "policy_sha256": { "const": "d9145b81171f22e0870be00fc811adf368bfb3c974be85bb702c0069e19dc8c1" },
        "runtime": {
          "type": "object",
          "additionalProperties": false,
          "required": ["http_timeout_seconds"],
          "properties": {
            "http_timeout_seconds": { "type": "number", "exclusiveMinimum": 0, "maximum": 300 }
          }
        }
      }
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "git_sha"],
      "properties": {
        "name": { "const": "reproassert" },
        "version": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._+-]{0,99}$" },
        "git_sha": { "$ref": "#/$defs/git_oid" }
      }
    }
  },
  "$defs": {
    "object_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "manifest_sha256",
        "entry_count",
        "blob_count",
        "regular_file_count",
        "directory_count",
        "symlink_count",
        "gitlink_count",
        "total_blob_bytes"
      ],
      "properties": {
        "algorithm": { "const": "reproassert-git-object-snapshot-v1" },
        "manifest_sha256": { "$ref": "#/$defs/sha256" },
        "entry_count": { "$ref": "#/$defs/nonnegative_integer" },
        "blob_count": { "$ref": "#/$defs/nonnegative_integer" },
        "regular_file_count": { "$ref": "#/$defs/nonnegative_integer" },
        "directory_count": { "$ref": "#/$defs/nonnegative_integer" },
        "symlink_count": { "$ref": "#/$defs/nonnegative_integer" },
        "gitlink_count": { "$ref": "#/$defs/nonnegative_integer" },
        "total_blob_bytes": { "$ref": "#/$defs/nonnegative_integer" }
      }
    },
    "transport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256",
        "bytes",
        "member_count",
        "regular_count",
        "directory_count",
        "symlink_count",
        "exact_blob_count",
        "repairs",
        "fallback_blob_oids"
      ],
      "properties": {
        "path": { "const": "source.tar.gz" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "bytes": { "$ref": "#/$defs/nonnegative_integer" },
        "member_count": { "$ref": "#/$defs/nonnegative_integer" },
        "regular_count": { "$ref": "#/$defs/nonnegative_integer" },
        "directory_count": { "$ref": "#/$defs/nonnegative_integer" },
        "symlink_count": { "$ref": "#/$defs/nonnegative_integer" },
        "exact_blob_count": { "$ref": "#/$defs/nonnegative_integer" },
        "repairs": {
          "type": "array",
          "maxItems": 64,
          "items": { "$ref": "#/$defs/repair" }
        },
        "fallback_blob_oids": {
          "type": "array",
          "maxItems": 64,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/git_oid" }
        }
      }
    },
    "repair": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "expected_oid", "reason", "observed_oid"],
      "properties": {
        "path": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "expected_oid": { "$ref": "#/$defs/git_oid" },
        "reason": { "enum": ["missing", "blob_oid_mismatch"] },
        "observed_oid": {
          "oneOf": [
            { "$ref": "#/$defs/git_oid" },
            { "type": "null" }
          ]
        }
      }
    },
    "verified_workspace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "tree_sha256",
        "git_root_tree_oid",
        "object_manifest_sha256",
        "regular_file_count",
        "directory_count",
        "symlink_count",
        "gitlink_count",
        "git_metadata_absent",
        "symlinks_root_confined",
        "gitlinks_uninitialized",
        "workspace_retained"
      ],
      "properties": {
        "algorithm": { "const": "reproassert-git-object-content-tree-v1" },
        "tree_sha256": { "$ref": "#/$defs/sha256" },
        "git_root_tree_oid": { "$ref": "#/$defs/git_oid" },
        "object_manifest_sha256": { "$ref": "#/$defs/sha256" },
        "regular_file_count": { "$ref": "#/$defs/nonnegative_integer" },
        "directory_count": { "$ref": "#/$defs/nonnegative_integer" },
        "symlink_count": { "$ref": "#/$defs/nonnegative_integer" },
        "gitlink_count": { "$ref": "#/$defs/nonnegative_integer" },
        "git_metadata_absent": { "const": true },
        "symlinks_root_confined": { "const": true },
        "gitlinks_uninitialized": { "const": true },
        "workspace_retained": { "const": false }
      }
    },
    "policy": {
      "const": {
        "id": "github-exact-object-source-v2",
        "network": {
          "scheme": "https",
          "metadata_and_blob_host": "api.github.com",
          "archive_host": "codeload.github.com",
          "authentication": "none",
          "proxy_environment": "disabled",
          "redirects": "rejected",
          "tls_minimum": "1.2",
          "commit_metadata_max_bytes": 524288,
          "recursive_tree_max_bytes": 8388608
        },
        "tree": {
          "source": "recursive_git_trees_api_exact_root_oid",
          "truncated_responses": "reject",
          "root_binding": "reconstructed_tree_oid_equals_commit_root_tree_oid",
          "mode_mapping": "api_040000_serializes_as_git_40000"
        },
        "transport": {
          "source": "codeload_full_40_hex_commit_sha",
          "format": "tar.gz",
          "preserved_filename": "source.tar.gz",
          "max_compressed_bytes": 67108864,
          "parser": "bounded_stream_no_extraction",
          "extra_duplicate_special_and_unsafe_members": "reject",
          "identity": "bulk_transport_only_not_git_identity"
        },
        "repair": {
          "source": "git_blobs_raw_api_by_exact_oid",
          "selection": "missing_or_oid_mismatched_blobs_only",
          "authentication": "none",
          "max_fallback_blobs": 64,
          "retries": 0
        },
        "verification": {
          "snapshot_algorithm": "reproassert-git-object-snapshot-v1",
          "content_tree_algorithm": "reproassert-git-object-content-tree-v1",
          "limits": {
            "max_entries": 20000,
            "max_blobs": 20000,
            "max_blob_bytes": 67108864,
            "max_total_blob_bytes": 268435456,
            "max_path_bytes": 4096,
            "max_component_bytes": 255,
            "max_symlink_target_bytes": 4096
          },
          "blob_identity": "git_sha1_verified_then_content_sha256_committed",
          "symlinks": "tracked_blob_verified_transitively_root_confined",
          "gitlinks": "attested_commit_oid_uninitialized_empty_directory",
          "submodule_recursion": "disabled"
        },
        "workspace": {
          "git_metadata": "absent",
          "materialization": "controller_owned_private_directory",
          "retention_after_validation": "removed_before_receipt_write"
        }
      }
    },
    "git_oid": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "nonnegative_integer": { "type": "integer", "minimum": 0, "maximum": 9223372036854775807 },
    "positive_integer": { "type": "integer", "minimum": 1, "maximum": 9223372036854775807 }
  }
}

