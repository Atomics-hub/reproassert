{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atomics-hub.github.io/reproassert/schemas/benchmark-event.schema.json",
  "title": "ReproAssert benchmark event",
  "description": "One canonical hash-chained event in a smoke or scored benchmark attempt ledger.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "benchmark_version",
    "lane",
    "sequence",
    "recorded_at",
    "previous_event_sha256",
    "event_sha256",
    "batch_id",
    "attempt_id",
    "case_id",
    "event_type",
    "payload"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "benchmark_version": { "const": "0.1.0" },
    "lane": { "type": "string", "enum": ["smoke", "scored"] },
    "sequence": { "type": "integer", "minimum": 1 },
    "recorded_at": { "$ref": "#/$defs/utcTimestamp" },
    "previous_event_sha256": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/sha256" }]
    },
    "event_sha256": { "$ref": "#/$defs/sha256" },
    "batch_id": { "$ref": "#/$defs/identifier" },
    "attempt_id": { "$ref": "#/$defs/identifier" },
    "case_id": { "type": "string", "pattern": "^rk-v0\\.1-[0-9]{3}$" },
    "event_type": {
      "type": "string",
      "enum": [
        "attempt_started",
        "phase_started",
        "phase_finished",
        "model_call_started",
        "model_call_finished",
        "cost_recorded",
        "candidate_submitted",
        "semantic_review_recorded",
        "gold_unblinded",
        "attempt_finished"
      ]
    },
    "payload": {
      "oneOf": [
        { "$ref": "#/$defs/attemptStarted" },
        { "$ref": "#/$defs/phaseStarted" },
        { "$ref": "#/$defs/phaseFinished" },
        { "$ref": "#/$defs/modelCallStarted" },
        { "$ref": "#/$defs/modelCallFinished" },
        { "$ref": "#/$defs/costRecorded" },
        { "$ref": "#/$defs/candidateSubmitted" },
        { "$ref": "#/$defs/semanticReviewRecorded" },
        { "$ref": "#/$defs/goldUnblinded" },
        { "$ref": "#/$defs/attemptFinished" }
      ]
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "gitSha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{2,127}$"
    },
    "utcTimestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$"
    },
    "phase": {
      "type": "string",
      "enum": [
        "preflight",
        "issue_snapshot",
        "dependency_prep",
        "generation",
        "candidate_policy",
        "collection",
        "base_verify",
        "fixed_verify",
        "causal_controls",
        "semantic_review",
        "gold_unblind"
      ]
    },
    "modelIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "value"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["reported", "alias_only", "unknown"]
        },
        "value": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1, "maxLength": 200 }
          ]
        }
      }
    },
    "campaignBudget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "campaign_id",
        "cohort_tier",
        "max_model_calls_per_case",
        "max_submitted_candidates_per_case",
        "max_infrastructure_retries_per_case",
        "max_case_wall_ms",
        "max_case_attributable_microusd",
        "max_campaign_attributable_microusd",
        "spend_authorization"
      ],
      "properties": {
        "campaign_id": { "$ref": "#/$defs/identifier" },
        "cohort_tier": {
          "type": "string",
          "enum": ["public_smoke", "historical_scored"]
        },
        "max_model_calls_per_case": { "const": 1 },
        "max_submitted_candidates_per_case": { "const": 1 },
        "max_infrastructure_retries_per_case": { "const": 1 },
        "max_case_wall_ms": { "type": "integer", "minimum": 1 },
        "max_case_attributable_microusd": {
          "type": "integer",
          "minimum": 0
        },
        "max_campaign_attributable_microusd": {
          "type": "integer",
          "minimum": 0
        },
        "spend_authorization": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "authorization_ref"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["offline_zero_cost", "explicit_user_approval"]
            },
            "authorization_ref": {
              "oneOf": [
                { "type": "null" },
                { "type": "string", "minLength": 3, "maxLength": 200 }
              ]
            }
          }
        }
      }
    },
    "attemptStarted": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "attempt_ordinal",
        "disposition",
        "retry_of",
        "campaign",
        "manifest_sha256",
        "case_entry_sha256",
        "tool",
        "generator",
        "policy_sha256",
        "pricing_snapshot_sha256"
      ],
      "properties": {
        "attempt_ordinal": { "type": "integer", "minimum": 1 },
        "disposition": {
          "type": "string",
          "enum": ["smoke_only", "primary_score", "infrastructure_retry"]
        },
        "retry_of": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/identifier" }]
        },
        "campaign": { "$ref": "#/$defs/campaignBudget" },
        "manifest_sha256": { "$ref": "#/$defs/sha256" },
        "case_entry_sha256": { "$ref": "#/$defs/sha256" },
        "tool": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version", "git_sha"],
          "properties": {
            "name": { "const": "reproassert" },
            "version": { "type": "string", "minLength": 1, "maxLength": 50 },
            "git_sha": { "$ref": "#/$defs/gitSha" }
          }
        },
        "generator": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "adapter",
            "provider",
            "requested_model",
            "model_identity",
            "prompt_template_sha256",
            "config_sha256",
            "request_builder_sha256",
            "context_algorithm_sha256",
            "feedback_policy",
            "submitted_candidate_budget"
          ],
          "properties": {
            "adapter": { "type": "string", "minLength": 1, "maxLength": 100 },
            "provider": { "type": "string", "minLength": 1, "maxLength": 100 },
            "requested_model": {
              "oneOf": [
                { "type": "null" },
                { "type": "string", "minLength": 1, "maxLength": 200 }
              ]
            },
            "model_identity": { "$ref": "#/$defs/modelIdentity" },
            "prompt_template_sha256": { "$ref": "#/$defs/sha256" },
            "config_sha256": { "$ref": "#/$defs/sha256" },
            "request_builder_sha256": { "$ref": "#/$defs/sha256" },
            "context_algorithm_sha256": { "$ref": "#/$defs/sha256" },
            "feedback_policy": { "const": "base_only_no_oracle" },
            "submitted_candidate_budget": { "const": 1 }
          }
        },
        "policy_sha256": { "$ref": "#/$defs/sha256" },
        "pricing_snapshot_sha256": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/sha256" }]
        }
      }
    },
    "phaseStarted": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase", "phase_ordinal", "started_at"],
      "properties": {
        "phase": { "$ref": "#/$defs/phase" },
        "phase_ordinal": { "type": "integer", "minimum": 1 },
        "started_at": { "$ref": "#/$defs/utcTimestamp" }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path", "sha256", "bytes"],
      "properties": {
        "kind": { "type": "string", "minLength": 1, "maxLength": 80 },
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500,
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
        },
        "sha256": { "$ref": "#/$defs/sha256" },
        "bytes": { "type": "integer", "minimum": 0 }
      }
    },
    "redactedLog": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy",
        "captured_bytes",
        "excerpt_bytes",
        "truncated",
        "excerpt_sha256",
        "excerpt"
      ],
      "properties": {
        "policy": { "const": "redacted_excerpt_v1" },
        "captured_bytes": { "type": "integer", "minimum": 0 },
        "excerpt_bytes": { "type": "integer", "minimum": 0, "maximum": 2048 },
        "truncated": { "type": "boolean" },
        "excerpt_sha256": { "$ref": "#/$defs/sha256" },
        "excerpt": { "type": "string", "maxLength": 2048 }
      }
    },
    "phaseFinished": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "phase",
        "phase_ordinal",
        "status",
        "started_at",
        "completed_at",
        "duration_ms",
        "classification_code",
        "command_sha256",
        "environment_sha256",
        "artifacts",
        "log"
      ],
      "properties": {
        "phase": { "$ref": "#/$defs/phase" },
        "phase_ordinal": { "type": "integer", "minimum": 1 },
        "status": {
          "type": "string",
          "enum": ["succeeded", "failed", "skipped"]
        },
        "started_at": { "$ref": "#/$defs/utcTimestamp" },
        "completed_at": { "$ref": "#/$defs/utcTimestamp" },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "classification_code": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1, "maxLength": 100 }
          ]
        },
        "command_sha256": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/sha256" }]
        },
        "environment_sha256": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/sha256" }]
        },
        "artifacts": {
          "type": "array",
          "maxItems": 32,
          "items": { "$ref": "#/$defs/artifact" }
        },
        "log": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/redactedLog" }]
        }
      }
    },
    "modelCallStarted": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "call_id",
        "started_at",
        "provider",
        "endpoint_host",
        "requested_model",
        "model_identity",
        "rendered_input_sha256",
        "config_sha256",
        "max_output_tokens",
        "pricing_snapshot_sha256",
        "reserved_worst_case_microusd"
      ],
      "properties": {
        "call_id": { "$ref": "#/$defs/identifier" },
        "started_at": { "$ref": "#/$defs/utcTimestamp" },
        "provider": { "type": "string", "minLength": 1, "maxLength": 100 },
        "endpoint_host": {
          "type": "string",
          "minLength": 1,
          "maxLength": 253,
          "pattern": "^[A-Za-z0-9.-]+$"
        },
        "requested_model": { "type": "string", "minLength": 1, "maxLength": 200 },
        "model_identity": { "$ref": "#/$defs/modelIdentity" },
        "rendered_input_sha256": { "$ref": "#/$defs/sha256" },
        "config_sha256": { "$ref": "#/$defs/sha256" },
        "max_output_tokens": { "type": "integer", "minimum": 1 },
        "pricing_snapshot_sha256": { "$ref": "#/$defs/sha256" },
        "reserved_worst_case_microusd": { "type": "integer", "minimum": 0 }
      }
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "input_tokens",
        "cached_input_tokens",
        "output_tokens",
        "total_tokens"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["reported", "estimated", "unknown", "not_applicable"]
        },
        "input_tokens": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "cached_input_tokens": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "output_tokens": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "total_tokens": {
          "type": ["integer", "null"],
          "minimum": 0
        }
      }
    },
    "modelCallFinished": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "call_id",
        "status",
        "started_at",
        "completed_at",
        "duration_ms",
        "response_model",
        "response_id_sha256",
        "classification_code",
        "usage"
      ],
      "properties": {
        "call_id": { "$ref": "#/$defs/identifier" },
        "status": {
          "type": "string",
          "enum": [
            "succeeded",
            "provider_error",
            "timeout",
            "invalid_response",
            "refusal",
            "cancelled"
          ]
        },
        "started_at": { "$ref": "#/$defs/utcTimestamp" },
        "completed_at": { "$ref": "#/$defs/utcTimestamp" },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "response_model": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "minLength": 1, "maxLength": 200 }
          ]
        },
        "response_id_sha256": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/sha256" }]
        },
        "classification_code": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "usage": { "$ref": "#/$defs/usage" }
      }
    },
    "costRecorded": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_id",
        "source_call_id",
        "category",
        "attribution",
        "status",
        "quantity",
        "unit",
        "unit_price_microusd",
        "amount_microusd",
        "source",
        "observed_at"
      ],
      "properties": {
        "entry_id": { "$ref": "#/$defs/identifier" },
        "source_call_id": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/identifier" }]
        },
        "category": {
          "type": "string",
          "enum": [
            "model_inference",
            "sandbox_compute",
            "artifact_transfer",
            "paid_storage",
            "dependency_prep",
            "human_review"
          ]
        },
        "attribution": {
          "type": "string",
          "enum": ["scored", "cold_prep_excluded", "human_labor_excluded"]
        },
        "status": {
          "type": "string",
          "enum": ["measured", "estimated", "unknown", "zero_verified"]
        },
        "quantity": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "pattern": "^[0-9]+(?:\\.[0-9]+)?$" }
          ]
        },
        "unit": { "type": "string", "minLength": 1, "maxLength": 50 },
        "unit_price_microusd": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "amount_microusd": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "source": { "type": "string", "minLength": 1, "maxLength": 300 },
        "observed_at": { "$ref": "#/$defs/utcTimestamp" }
      }
    },
    "candidateSubmitted": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_index",
        "patch_sha256",
        "artifact_path",
        "changed_files",
        "nodeids",
        "added_lines",
        "deleted_lines",
        "selected_rank",
        "generation_call_ids",
        "oracle_consulted"
      ],
      "properties": {
        "candidate_index": { "type": "integer", "minimum": 1 },
        "patch_sha256": { "$ref": "#/$defs/sha256" },
        "artifact_path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500,
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
        },
        "changed_files": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 500 }
        },
        "nodeids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 500 }
        },
        "added_lines": { "type": "integer", "minimum": 0 },
        "deleted_lines": { "type": "integer", "minimum": 0 },
        "selected_rank": { "const": 1 },
        "generation_call_ids": {
          "type": "array",
          "maxItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/identifier" }
        },
        "oracle_consulted": { "const": false }
      }
    },
    "semanticReviewRecorded": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reviewer_id",
        "role",
        "blinded",
        "packet_sha256",
        "trigger_faithful",
        "oracle_supported",
        "failure_causal",
        "implementation_independent",
        "minimal_and_readable",
        "verdict",
        "confidence",
        "rationale"
      ],
      "properties": {
        "reviewer_id": { "$ref": "#/$defs/identifier" },
        "role": { "type": "string", "enum": ["primary", "tie_break"] },
        "blinded": { "const": true },
        "packet_sha256": { "$ref": "#/$defs/sha256" },
        "trigger_faithful": { "type": "boolean" },
        "oracle_supported": { "type": "boolean" },
        "failure_causal": { "type": "boolean" },
        "implementation_independent": { "type": "boolean" },
        "minimal_and_readable": { "type": "boolean" },
        "verdict": { "type": "string", "enum": ["valid", "invalid"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "rationale": { "type": "string", "minLength": 1, "maxLength": 2000 }
      }
    },
    "goldUnblinded": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "committed_semantic_event_sha256",
        "artifact_bundle_sha256",
        "unblinded_at"
      ],
      "properties": {
        "committed_semantic_event_sha256": { "$ref": "#/$defs/sha256" },
        "artifact_bundle_sha256": { "$ref": "#/$defs/sha256" },
        "unblinded_at": { "$ref": "#/$defs/utcTimestamp" }
      }
    },
    "attemptFinished": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "completed_at",
        "outcome",
        "claim_level",
        "scoring_disposition",
        "plausible_f2p",
        "result_row_sha256",
        "limitations"
      ],
      "properties": {
        "completed_at": { "$ref": "#/$defs/utcTimestamp" },
        "outcome": {
          "type": "string",
          "enum": [
            "benchmark_infrastructure_error",
            "no_output",
            "invalid_patch",
            "policy_violation",
            "setup_failure",
            "collect_failure",
            "pass_on_base",
            "wrong_failure",
            "flaky_base",
            "fail_on_fix",
            "flaky_fix",
            "plausible_f2p_semantic_invalid",
            "semantic_valid"
          ]
        },
        "claim_level": {
          "type": "string",
          "enum": ["rejected", "L0", "L1", "L2"]
        },
        "scoring_disposition": {
          "type": "string",
          "enum": ["counted", "retriable_infrastructure", "non_scoring"]
        },
        "plausible_f2p": { "type": "boolean" },
        "result_row_sha256": {
          "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/sha256" }]
        },
        "limitations": {
          "type": "array",
          "maxItems": 20,
          "items": { "type": "string", "minLength": 1, "maxLength": 500 }
        }
      }
    }
  }
}
