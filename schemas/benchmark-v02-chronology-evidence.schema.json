{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Atomics-hub/reproassert/blob/main/schemas/benchmark-v02-chronology-evidence.schema.json",
  "title": "ReproAssert v0.2 chronology evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["algorithm", "benchmark_version", "captured_at", "case_count", "cases", "claims", "inputs", "receipt_sha256", "schema_version", "status", "tool_git_sha"],
  "properties": {
    "algorithm": {"const": "reproassert-v02-chronology-evidence-v1"},
    "benchmark_version": {"const": "0.2"},
    "captured_at": {"$ref": "#/$defs/timestamp"},
    "case_count": {"const": 20},
    "cases": {
      "type": "array", "minItems": 20, "maxItems": 20,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["case_id", "fix_artifact_created_at", "hidden_metadata_sha256", "issue_created_at", "issue_response_sha256", "issue_url", "lead_time_seconds", "repo", "status"],
        "properties": {
          "case_id": {"$ref": "#/$defs/case_id"},
          "fix_artifact_created_at": {"$ref": "#/$defs/timestamp"},
          "hidden_metadata_sha256": {"$ref": "#/$defs/sha256"},
          "issue_created_at": {"$ref": "#/$defs/timestamp"},
          "issue_response_sha256": {"$ref": "#/$defs/sha256"},
          "issue_url": {"type": "string", "pattern": "^https://github\\.com/[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+/issues/[1-9][0-9]*$"},
          "lead_time_seconds": {"type": "integer", "minimum": 1},
          "repo": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"},
          "status": {"const": "issue_precedes_fix"}
        }
      }
    },
    "claims": {
      "const": {
        "chronology_proven_count": 20,
        "hidden_bytes_emitted": false,
        "model_or_provider_invoked": false,
        "provider_calls": 0
      }
    },
    "inputs": {
      "type": "object", "additionalProperties": false,
      "required": ["cohort_plan_sha256", "hidden_extraction_receipt_sha256", "hidden_metadata_set_sha256", "issue_response_set_sha256"],
      "properties": {
        "cohort_plan_sha256": {"$ref": "#/$defs/sha256"},
        "hidden_extraction_receipt_sha256": {"$ref": "#/$defs/sha256"},
        "hidden_metadata_set_sha256": {"$ref": "#/$defs/sha256"},
        "issue_response_set_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "receipt_sha256": {"$ref": "#/$defs/sha256"},
    "schema_version": {"const": "1.0.0"},
    "status": {"const": "issue_precedes_fix_20_of_20"},
    "tool_git_sha": {"$ref": "#/$defs/git_sha"}
  },
  "$defs": {
    "case_id": {"type": "string", "pattern": "^rk-v0\\.2-[0-9]{3}$"},
    "git_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "timestamp": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$"}
  }
}
