{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Atomics-hub/reproassert/blob/main/schemas/benchmark-v02-semantic-verification.schema.json",
  "title": "ReproAssert v0.2 trusted semantic verification result",
  "description": "Evaluator-only canonical output from application-selected controller code. It binds dataset membership, causal tree reconstruction, source and dependency receipts, production generator isolation, and reviewer-role sealing.",
  "type": "object",
  "additionalProperties": false,
  "required": ["algorithm", "case", "completed_at", "tdd_bench_git_sha", "tdd_bench_root_tree_oid", "tdd_id_list_path", "tdd_id_list_blob_oid", "tdd_id_list_sha256", "tdd_membership_ordinal", "source_dataset_git_sha", "source_dataset_root_tree_oid", "source_dataset_split", "source_dataset_artifact_path", "source_dataset_artifact_git_blob_oid", "source_dataset_lfs_pointer_sha256", "source_dataset_artifact_lfs_sha256", "source_dataset_artifact_lfs_bytes", "source_dataset_artifact_xet_sha256", "source_dataset_artifact_sha256", "source_dataset_row_ordinal", "source_dataset_row_sha256", "source_dataset_transform", "dataset_evidence_sha256", "source_receipt_sha256", "source_base_commit_sha", "source_base_root_tree_oid", "source_tree_sha256", "source_context_algorithm", "source_context_policy_sha256", "source_context_sha256", "production_patch_sha256", "developer_tests_sha256", "hidden_fixed_root_tree_oid", "reconstructed_pr_head_root_tree_oid", "fixing_head_commit_sha", "fixing_head_root_tree_oid", "dependency_receipt_sha256", "dependency_case_id", "dependency_base_sha", "dependency_source_tree_sha256", "dependency_environment_setup_commit", "dependency_runner_image_id", "isolation_receipt_sha256", "isolation_policy_sha256", "scored_generator_mode", "arbitrary_host_command_generator_allowed", "evaluator_paths_exposed", "host_credentials_forwarded", "network_after_dependency_prep", "production_isolation_accepted", "reviewer_role_seal_sha256", "reviewer_roles_sealed", "semantic_reviewer_ids", "gold_hidden_until_verdict"],
  "properties": {
    "algorithm": { "const": "reproassert-v02-semantic-verification-v1" },
    "case": { "$ref": "#/$defs/case" },
    "completed_at": { "$ref": "#/$defs/timestamp" },
    "tdd_bench_git_sha": { "$ref": "#/$defs/gitSha" },
    "tdd_bench_root_tree_oid": { "$ref": "#/$defs/gitSha" },
    "tdd_id_list_path": { "const": "id_list.txt" },
    "tdd_id_list_blob_oid": { "$ref": "#/$defs/gitSha" },
    "tdd_id_list_sha256": { "$ref": "#/$defs/sha256" },
    "tdd_membership_ordinal": { "type": "integer", "minimum": 1, "maximum": 449 },
    "source_dataset_git_sha": { "$ref": "#/$defs/gitSha" },
    "source_dataset_root_tree_oid": { "$ref": "#/$defs/gitSha" },
    "source_dataset_split": { "const": "test" },
    "source_dataset_artifact_path": { "const": "default/test/0000.parquet" },
    "source_dataset_artifact_git_blob_oid": { "$ref": "#/$defs/gitSha" },
    "source_dataset_lfs_pointer_sha256": { "$ref": "#/$defs/sha256" },
    "source_dataset_artifact_lfs_sha256": { "$ref": "#/$defs/sha256" },
    "source_dataset_artifact_lfs_bytes": { "type": "integer", "minimum": 1 },
    "source_dataset_artifact_xet_sha256": { "$ref": "#/$defs/sha256" },
    "source_dataset_artifact_sha256": { "$ref": "#/$defs/sha256" },
    "source_dataset_row_ordinal": { "type": "integer", "minimum": 0 },
    "source_dataset_row_sha256": { "$ref": "#/$defs/sha256" },
    "source_dataset_transform": { "const": "drop_PASS_TO_PASS_and_FAIL_TO_PASS_v1" },
    "dataset_evidence_sha256": { "$ref": "#/$defs/sha256" },
    "source_receipt_sha256": { "$ref": "#/$defs/sha256" },
    "source_base_commit_sha": { "$ref": "#/$defs/gitSha" },
    "source_base_root_tree_oid": { "$ref": "#/$defs/gitSha" },
    "source_tree_sha256": { "$ref": "#/$defs/sha256" },
    "source_context_algorithm": { "const": "reproassert-v02-source-context-v1" },
    "source_context_policy_sha256": { "$ref": "#/$defs/sha256" },
    "source_context_sha256": { "$ref": "#/$defs/sha256" },
    "production_patch_sha256": { "$ref": "#/$defs/sha256" },
    "developer_tests_sha256": { "$ref": "#/$defs/sha256" },
    "hidden_fixed_root_tree_oid": { "$ref": "#/$defs/gitSha" },
    "reconstructed_pr_head_root_tree_oid": { "$ref": "#/$defs/gitSha" },
    "fixing_head_commit_sha": { "$ref": "#/$defs/gitSha" },
    "fixing_head_root_tree_oid": { "$ref": "#/$defs/gitSha" },
    "dependency_receipt_sha256": { "$ref": "#/$defs/sha256" },
    "dependency_case_id": { "type": "string", "pattern": "^rk-v0\\.2-[0-9]{3}$" },
    "dependency_base_sha": { "$ref": "#/$defs/gitSha" },
    "dependency_source_tree_sha256": { "$ref": "#/$defs/sha256" },
    "dependency_environment_setup_commit": { "$ref": "#/$defs/gitSha" },
    "dependency_runner_image_id": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "isolation_receipt_sha256": { "$ref": "#/$defs/sha256" },
    "isolation_policy_sha256": { "$ref": "#/$defs/sha256" },
    "scored_generator_mode": { "enum": ["trusted_builtin_provider_adapter", "sandboxed_generator_process"] },
    "arbitrary_host_command_generator_allowed": { "const": false },
    "evaluator_paths_exposed": { "const": false },
    "host_credentials_forwarded": { "const": false },
    "network_after_dependency_prep": { "const": "disabled" },
    "production_isolation_accepted": { "const": true },
    "reviewer_role_seal_sha256": { "$ref": "#/$defs/sha256" },
    "reviewer_roles_sealed": { "const": true },
    "semantic_reviewer_ids": { "type": "array", "minItems": 2, "maxItems": 3, "uniqueItems": true, "items": { "$ref": "#/$defs/identifier" } },
    "gold_hidden_until_verdict": { "const": true }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "gitSha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "identifier": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{2,127}$" },
    "timestamp": { "type": "string", "format": "date-time", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$" },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "repo", "issue_url", "base_sha"],
      "properties": {
        "id": { "type": "string", "pattern": "^rk-v0\\.2-[0-9]{3}$" },
        "repo": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
        "issue_url": { "type": "string", "pattern": "^https://github\\.com/[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+/issues/[1-9][0-9]*$" },
        "base_sha": { "$ref": "#/$defs/gitSha" }
      }
    }
  }
}
