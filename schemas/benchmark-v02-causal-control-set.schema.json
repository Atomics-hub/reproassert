{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Atomics-hub/reproassert/blob/main/schemas/benchmark-v02-causal-control-set.schema.json",
  "title": "ReproAssert v0.2 executed causal-control receipt set",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "benchmark_version",
    "algorithm",
    "status",
    "campaign_id",
    "campaign_freeze_sha256",
    "preregistration_sha256",
    "cohort_sha256",
    "sealed_at",
    "execution_contract",
    "cases",
    "tool",
    "control_set_sha256"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "benchmark_version": { "const": "0.2.0-draft" },
    "algorithm": { "const": "reproassert-v02-causal-control-set-v1" },
    "status": { "const": "sealed_complete" },
    "campaign_id": { "$ref": "#/$defs/identifier" },
    "campaign_freeze_sha256": { "$ref": "#/$defs/sha256" },
    "preregistration_sha256": { "$ref": "#/$defs/sha256" },
    "cohort_sha256": { "$ref": "#/$defs/sha256" },
    "sealed_at": { "$ref": "#/$defs/timestamp" },
    "execution_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_control_types",
        "real_sandbox_boundary_required",
        "host_secrets_exposed",
        "network_after_dependency_prep",
        "resource_limits_required",
        "declared_decoys_frozen_before_gold_unblinding",
        "unavailable_or_inconclusive_controls_cannot_pass_l2"
      ],
      "properties": {
        "required_control_types": {
          "const": [
            "candidate_on_fixed",
            "fix_minus_issue_relevant_hunks",
            "base_plus_issue_relevant_hunks"
          ]
        },
        "real_sandbox_boundary_required": { "const": true },
        "host_secrets_exposed": { "const": false },
        "network_after_dependency_prep": { "const": "disabled" },
        "resource_limits_required": { "const": true },
        "declared_decoys_frozen_before_gold_unblinding": { "const": true },
        "unavailable_or_inconclusive_controls_cannot_pass_l2": { "const": true }
      }
    },
    "cases": {
      "type": "array",
      "minItems": 20,
      "maxItems": 20,
      "items": { "$ref": "#/$defs/control_case" }
    },
    "tool": { "$ref": "#/$defs/tool" },
    "control_set_sha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "git_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{2,127}$"
    },
    "case_id": { "type": "string", "pattern": "^rk-v0\\.2-[0-9]{3}$" },
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$"
    },
    "nullable_sha256": {
      "oneOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }]
    },
    "nullable_timestamp": {
      "oneOf": [{ "$ref": "#/$defs/timestamp" }, { "type": "null" }]
    },
    "control_case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "case_id",
        "candidate_sha256",
        "evaluator_commitment_sha256",
        "issue_relevant_hunks_sha256",
        "fixed_pass_evidence_sha256",
        "status",
        "completed_at",
        "declared_decoy_control_ids",
        "controls",
        "required_controls_passed",
        "declared_decoys_passed",
        "l2_causal_controls_passed",
        "control_receipt_sha256"
      ],
      "properties": {
        "algorithm": { "const": "reproassert-v02-causal-control-receipt-v1" },
        "case_id": { "$ref": "#/$defs/case_id" },
        "candidate_sha256": { "$ref": "#/$defs/nullable_sha256" },
        "evaluator_commitment_sha256": { "$ref": "#/$defs/sha256" },
        "issue_relevant_hunks_sha256": { "$ref": "#/$defs/nullable_sha256" },
        "fixed_pass_evidence_sha256": { "$ref": "#/$defs/nullable_sha256" },
        "status": { "enum": ["executed", "not_applicable_no_candidate"] },
        "completed_at": { "$ref": "#/$defs/nullable_timestamp" },
        "declared_decoy_control_ids": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/identifier" }
        },
        "controls": {
          "type": "array",
          "maxItems": 35,
          "items": { "$ref": "#/$defs/control_run" }
        },
        "required_controls_passed": { "type": "boolean" },
        "declared_decoys_passed": { "type": "boolean" },
        "l2_causal_controls_passed": { "type": "boolean" },
        "control_receipt_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "control_run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "control_id",
        "control_type",
        "expected_outcome",
        "observed_outcome",
        "executed_at",
        "test_command",
        "exit_code",
        "duration_ms",
        "timed_out",
        "oom_killed",
        "output_truncated",
        "output_sha256",
        "junit_sha256",
        "sandbox_receipt_sha256",
        "environment_sha256",
        "reason",
        "control_run_sha256"
      ],
      "properties": {
        "algorithm": { "const": "reproassert-v02-causal-control-run-v1" },
        "control_id": { "$ref": "#/$defs/identifier" },
        "control_type": {
          "enum": [
            "candidate_on_fixed",
            "fix_minus_issue_relevant_hunks",
            "base_plus_issue_relevant_hunks",
            "declared_decoy"
          ]
        },
        "expected_outcome": { "enum": ["pass", "fail"] },
        "observed_outcome": {
          "enum": [
            "pass",
            "fail",
            "infra_error",
            "timeout",
            "not_available",
            "inconclusive"
          ]
        },
        "executed_at": { "$ref": "#/$defs/nullable_timestamp" },
        "test_command": {
          "oneOf": [
            { "type": "string", "minLength": 1, "maxLength": 500 },
            { "type": "null" }
          ]
        },
        "exit_code": {
          "oneOf": [
            { "type": "integer", "minimum": 0, "maximum": 255 },
            { "type": "null" }
          ]
        },
        "duration_ms": {
          "oneOf": [
            { "type": "integer", "minimum": 0, "maximum": 3600000 },
            { "type": "null" }
          ]
        },
        "timed_out": { "type": "boolean" },
        "oom_killed": { "type": "boolean" },
        "output_truncated": { "type": "boolean" },
        "output_sha256": { "$ref": "#/$defs/nullable_sha256" },
        "junit_sha256": { "$ref": "#/$defs/nullable_sha256" },
        "sandbox_receipt_sha256": { "$ref": "#/$defs/nullable_sha256" },
        "environment_sha256": { "$ref": "#/$defs/nullable_sha256" },
        "reason": {
          "oneOf": [
            { "type": "string", "minLength": 10, "maxLength": 500 },
            { "type": "null" }
          ]
        },
        "control_run_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "git_sha"],
      "properties": {
        "name": { "$ref": "#/$defs/identifier" },
        "version": { "type": "string", "minLength": 1, "maxLength": 64 },
        "git_sha": { "$ref": "#/$defs/git_sha" }
      }
    }
  }
}
