{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Atomics-hub/reproassert/blob/main/schemas/benchmark-v02-private-result.schema.json",
  "title": "ReproAssert v0.2 private scored result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "benchmark_version",
    "algorithm",
    "visibility",
    "campaign_id",
    "attempt_id",
    "case",
    "preregistration_sha256",
    "cohort_sha256",
    "runner_input_sha256",
    "configuration_sha256",
    "source_context",
    "candidate",
    "evaluation",
    "terminal_projection",
    "cost",
    "ledger_head_before_result_sha256"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "benchmark_version": { "const": "0.2.0-draft" },
    "algorithm": { "const": "reproassert-v02-scored-result-v1" },
    "visibility": { "const": "private_controller_only" },
    "campaign_id": { "$ref": "#/$defs/identifier" },
    "attempt_id": { "$ref": "#/$defs/identifier" },
    "case": { "$ref": "#/$defs/case" },
    "preregistration_sha256": { "$ref": "#/$defs/sha256" },
    "cohort_sha256": { "$ref": "#/$defs/sha256" },
    "runner_input_sha256": { "$ref": "#/$defs/sha256" },
    "configuration_sha256": { "$ref": "#/$defs/sha256" },
    "source_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "policy_sha256", "sha256"],
      "properties": {
        "algorithm": { "$ref": "#/$defs/identifier" },
        "policy_sha256": { "$ref": "#/$defs/sha256" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "candidate": {
      "oneOf": [{ "$ref": "#/$defs/candidate" }, { "type": "null" }]
    },
    "evaluation": {
      "oneOf": [{ "$ref": "#/$defs/evaluation" }, { "type": "null" }]
    },
    "terminal_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "outcome",
        "claim_level",
        "classification_code",
        "issue_faithful_or_semantic_valid",
        "limitation"
      ],
      "properties": {
        "outcome": { "$ref": "#/$defs/code" },
        "claim_level": { "$ref": "#/$defs/claim" },
        "classification_code": { "$ref": "#/$defs/code" },
        "issue_faithful_or_semantic_valid": { "const": false },
        "limitation": { "type": "string", "minLength": 1, "maxLength": 400 }
      }
    },
    "cost": { "$ref": "#/$defs/cost" },
    "ledger_head_before_result_sha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "git_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{2,127}$"
    },
    "code": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,99}$" },
    "claim": {
      "enum": [
        "rejected",
        "collected",
        "repeatable_base_failure",
        "differential_reproduction"
      ]
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "repo",
        "issue_url",
        "base_sha",
        "difficulty",
        "smoke",
        "generator_projection_sha256",
        "evaluator_commitment_sha256",
        "source_context_sha256"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^rk-v0\\.2-[0-9]{3}$" },
        "repo": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
        "issue_url": {
          "type": "string",
          "pattern": "^https://github\\.com/[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+/issues/[1-9][0-9]*$"
        },
        "base_sha": { "$ref": "#/$defs/git_sha" },
        "difficulty": { "enum": ["lt_15m", "15m_to_1h"] },
        "smoke": { "type": "boolean" },
        "generator_projection_sha256": { "$ref": "#/$defs/sha256" },
        "evaluator_commitment_sha256": { "$ref": "#/$defs/sha256" },
        "source_context_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "bytes", "test_content", "expected_symptom", "rationale"],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^tests/reproassert/test_issue_[1-9][0-9]*\\.py$"
        },
        "sha256": { "$ref": "#/$defs/sha256" },
        "bytes": { "type": "integer", "minimum": 1, "maximum": 32768 },
        "test_content": { "type": "string", "minLength": 1, "maxLength": 32768 },
        "expected_symptom": { "type": "string", "minLength": 3, "maxLength": 500 },
        "rationale": { "type": "string", "minLength": 3, "maxLength": 2000 }
      }
    },
    "nullable_sha256": {
      "oneOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }]
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "accepted_mechanical_differential",
        "mechanical_claim_level",
        "outcome",
        "fingerprint",
        "base_run_count",
        "fixed_run_count",
        "scheduled_runs",
        "evaluator_capability_sha256",
        "evaluator_package_sha256",
        "evaluator_commitment_sha256",
        "dependency",
        "semantic_status"
      ],
      "properties": {
        "accepted_mechanical_differential": { "type": "boolean" },
        "mechanical_claim_level": { "$ref": "#/$defs/claim" },
        "outcome": { "$ref": "#/$defs/code" },
        "fingerprint": {
          "oneOf": [
            { "type": "string", "minLength": 1, "maxLength": 2000 },
            { "type": "null" }
          ]
        },
        "base_run_count": { "type": "integer", "minimum": 0, "maximum": 3 },
        "fixed_run_count": { "type": "integer", "minimum": 0, "maximum": 3 },
        "scheduled_runs": {
          "type": "array",
          "maxItems": 6,
          "items": { "$ref": "#/$defs/scheduled_run" }
        },
        "evaluator_capability_sha256": { "$ref": "#/$defs/sha256" },
        "evaluator_package_sha256": { "$ref": "#/$defs/sha256" },
        "evaluator_commitment_sha256": { "$ref": "#/$defs/sha256" },
        "dependency": {
          "type": "object",
          "additionalProperties": false,
          "required": ["receipt_sha256", "plan_sha256", "tree_sha256", "image_id"],
          "properties": {
            "receipt_sha256": { "$ref": "#/$defs/nullable_sha256" },
            "plan_sha256": { "$ref": "#/$defs/nullable_sha256" },
            "tree_sha256": { "$ref": "#/$defs/nullable_sha256" },
            "image_id": {
              "oneOf": [
                { "type": "string", "minLength": 3, "maxLength": 200 },
                { "type": "null" }
              ]
            }
          }
        },
        "semantic_status": { "const": "not_reviewed_mechanical_result_only" }
      }
    },
    "scheduled_run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_role",
        "role_ordinal",
        "schedule_ordinal",
        "phase",
        "argv",
        "exit_code",
        "duration_seconds",
        "timed_out",
        "oom_killed",
        "output_truncated",
        "bounded_output",
        "output_sha256",
        "junit_sha256",
        "evaluator_output_redacted"
      ],
      "properties": {
        "source_role": { "enum": ["base", "fixed"] },
        "role_ordinal": { "type": "integer", "minimum": 1, "maximum": 3 },
        "schedule_ordinal": { "type": "integer", "minimum": 1, "maximum": 6 },
        "phase": { "pattern": "^(?:base|fixed)_[1-3]$" },
        "argv": {
          "type": "array",
          "minItems": 1,
          "maxItems": 20,
          "items": { "type": "string", "minLength": 1, "maxLength": 500 }
        },
        "exit_code": {
          "oneOf": [{ "type": "integer", "minimum": 0, "maximum": 255 }, { "type": "null" }]
        },
        "duration_seconds": { "type": "number", "minimum": 0 },
        "timed_out": { "type": "boolean" },
        "oom_killed": { "type": "boolean" },
        "output_truncated": { "type": "boolean" },
        "bounded_output": {
          "oneOf": [
            { "type": "string", "maxLength": 65536 },
            { "type": "null" }
          ]
        },
        "output_sha256": { "$ref": "#/$defs/sha256" },
        "junit_sha256": { "$ref": "#/$defs/nullable_sha256" },
        "evaluator_output_redacted": { "type": "boolean" }
      },
      "allOf": [
        {
          "if": { "properties": { "source_role": { "const": "fixed" } } },
          "then": {
            "properties": {
              "bounded_output": { "type": "null" },
              "evaluator_output_redacted": { "const": true }
            }
          }
        },
        {
          "if": { "properties": { "source_role": { "const": "base" } } },
          "then": {
            "properties": {
              "bounded_output": { "type": "string" },
              "evaluator_output_redacted": { "const": false }
            }
          }
        }
      ]
    },
    "cost": {
      "type": "object",
      "additionalProperties": false,
      "required": ["complete", "total_attributable_microusd", "categories", "pricing_snapshot_sha256"],
      "properties": {
        "complete": { "type": "boolean" },
        "total_attributable_microusd": {
          "oneOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
        },
        "categories": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "model_inference",
            "sandbox_compute",
            "artifact_transfer",
            "paid_storage",
            "dependency_prep"
          ],
          "properties": {
            "model_inference": { "$ref": "#/$defs/nullable_cost" },
            "sandbox_compute": { "$ref": "#/$defs/nullable_cost" },
            "artifact_transfer": { "$ref": "#/$defs/nullable_cost" },
            "paid_storage": { "$ref": "#/$defs/nullable_cost" },
            "dependency_prep": { "$ref": "#/$defs/nullable_cost" }
          }
        },
        "pricing_snapshot_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "nullable_cost": {
      "oneOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }]
    }
  }
}
