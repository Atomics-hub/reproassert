{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Atomics-hub/reproassert/blob/main/schemas/benchmark-v02-execution-freeze.schema.json",
  "title": "ReproAssert v0.2 exact-image execution freeze",
  "type": "object",
  "additionalProperties": false,
  "required": ["algorithm", "benchmark_version", "campaign", "claims", "controller_git_sha", "evidence", "execution", "execution_freeze_sha256", "prepared_at", "pricing_snapshot", "pricing_snapshot_sha256", "provider", "request_set", "schema_version", "status"],
  "properties": {
    "algorithm": {"const": "reproassert-v02-exact-image-execution-freeze-v1"},
    "benchmark_version": {"const": "0.2"},
    "campaign": {
      "type": "object", "additionalProperties": false,
      "required": ["campaign_freeze_sha256", "campaign_id", "case_count", "cohort_sha256", "preregistration_sha256"],
      "properties": {
        "campaign_freeze_sha256": {"$ref": "#/$defs/sha256"}, "campaign_id": {"$ref": "#/$defs/identifier"},
        "case_count": {"const": 20}, "cohort_sha256": {"$ref": "#/$defs/sha256"}, "preregistration_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "claims": {
      "const": {"credentials_read": false, "hidden_data_included": false, "provider_calls": 0, "provider_invoked_by_this_command": false}
    },
    "controller_git_sha": {"$ref": "#/$defs/git_sha"},
    "evidence": {
      "type": "object", "additionalProperties": false,
      "required": ["cases_preparation_receipt_sha256", "gold_smoke_receipt_sha256", "instance_runtime_manifest_sha256", "source_context_policy_sha256"],
      "properties": {
        "cases_preparation_receipt_sha256": {"$ref": "#/$defs/sha256"}, "gold_smoke_receipt_sha256": {"$ref": "#/$defs/sha256"}, "instance_runtime_manifest_sha256": {"$ref": "#/$defs/sha256"}, "source_context_policy_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "execution": {
      "type": "object", "additionalProperties": false,
      "required": ["authorization_scope", "max_campaign_attributable_microusd", "max_case_attributable_microusd", "max_case_wall_ms", "max_output_tokens", "overage_permitted", "provider_timeout_ms", "reservation_total_microusd", "reservations"],
      "properties": {
        "authorization_scope": {"const": "one_campaign_one_attempt_per_case"}, "max_campaign_attributable_microusd": {"const": 5000000},
        "max_case_attributable_microusd": {"const": 250000}, "max_case_wall_ms": {"const": 600000}, "max_output_tokens": {"const": 4096},
        "overage_permitted": {"const": false}, "provider_timeout_ms": {"const": 120000},
        "reservation_total_microusd": {"type": "integer", "minimum": 1, "maximum": 5000000},
        "reservations": {"type": "array", "minItems": 20, "maxItems": 20, "items": {"type": "object", "additionalProperties": false, "required": ["case_id", "worst_case_microusd"], "properties": {"case_id": {"$ref": "#/$defs/case_id"}, "worst_case_microusd": {"type": "integer", "minimum": 1, "maximum": 250000}}}}
      }
    },
    "execution_freeze_sha256": {"$ref": "#/$defs/sha256"},
    "prepared_at": {"$ref": "#/$defs/timestamp"},
    "pricing_snapshot": {"type": "object"},
    "pricing_snapshot_sha256": {"$ref": "#/$defs/sha256"},
    "provider": {
      "type": "object", "additionalProperties": false, "required": ["endpoint_host", "name", "requested_model"],
      "properties": {"endpoint_host": {"const": "api.openai.com"}, "name": {"const": "openai"}, "requested_model": {"$ref": "#/$defs/model"}}
    },
    "request_set": {
      "type": "object", "additionalProperties": false,
      "required": ["algorithm", "preparation_request_set_sha256", "request_count", "request_set_sha256", "requests"],
      "properties": {
        "algorithm": {"const": "reproassert-v02-execution-request-set-v1"}, "preparation_request_set_sha256": {"$ref": "#/$defs/sha256"},
        "request_count": {"const": 20}, "request_set_sha256": {"$ref": "#/$defs/sha256"},
        "requests": {"type": "array", "minItems": 20, "maxItems": 20, "items": {"type": "object", "additionalProperties": false, "required": ["case_id", "rendered_input_sha256"], "properties": {"case_id": {"$ref": "#/$defs/case_id"}, "rendered_input_sha256": {"$ref": "#/$defs/sha256"}}}}
      }
    },
    "schema_version": {"const": "1.0.0"},
    "status": {"const": "prepared_exact_inputs_provider_not_authorized"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "git_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "case_id": {"type": "string", "pattern": "^rk-v0\\.2-[0-9]{3}$"}, "identifier": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{2,127}$"},
    "model": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"},
    "timestamp": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$"}
  }
}
